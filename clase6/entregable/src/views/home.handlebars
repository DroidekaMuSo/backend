{{#if products}}
    <h1>Products</h1>
    {{#each products}}
        <h2>{{this.title}}</h2>
        <p><b>Description:</b> {{this.description}}</p>
        <p><b>Price:</b> {{this.price}}</p>
        <p><b>Stock:</b> {{this.stock}}</p>
    {{/each}}
{{else}}
    <h1>There's nothing in the cart</h1>
{{/if}}